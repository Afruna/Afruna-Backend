# ==========================================
# AFRUNA DEVELOPMENT ENVIRONMENT CONFIGURATION
# ==========================================

# Server
NODE_ENV=development
PORT=3000

# Database
DB_URI=mongodb://localhost:27017/afruna_dev

# JWT Configuration
JWT_KEY=dev_jwt_secret_key
JWT_TIMEOUT=1d
REFRESH_JWT_KEY=dev_refresh_jwt_secret_key
REFRESH_JWT_TIMEOUT=7d

# Redis
REDIS_URI=redis://localhost:6379

# Email Configuration (use Mailtrap for testing)
SMTP_SERVICE=mailtrap
SMTP_HOSTNAME=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=your_mailtrap_username
SMTP_PASSWORD=your_mailtrap_password

# Company Info
DOMAIN_EMAIL=noreply@afruna.test
COMPANY_ADDRESS="Test Address"
COMPANY_NAME=Afruna Dev
COMPANY_DOMAIN=http://localhost:3000

# Admin Seeder
SEEDER_EMAIL=admin@afruna.test
SEEDER_PASSWORD=admin123

# ==========================================
# PAYMENT & SHIPPING CONFIGURATION (SANDBOX)
# ==========================================

# Paystack (TEST/SANDBOX)
PAYSTACK_SECRET=sk_test_your_test_paystack_secret_key
PAYSTACK_REDIRECT=http://localhost:3000/paystack-callback
PAYSTACK_BASE_URL=https://api.paystack.co
ORDER_REDIRECT=http://localhost:3000/order-success
WALLET_REDIRECT=http://localhost:3000/wallet-success

# Shipbubble (SANDBOX)
SHIPBUBBLE_API_KEY=sb_test_your_test_shipbubble_api_key
SHIPBUBBLE_BASE_URL=https://api.shipbubble.com/v1

# ==========================================
# STORAGE CONFIGURATION
# ==========================================

# Local file storage for development
MULTER_STORAGE_PATH=uploads/

# VAT/Tax Rate
VAT_FEE=7.5
