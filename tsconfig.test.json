{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": false,
    "noEmitOnError": false,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["jest", "node"]
  },
  "include": ["src/**/*", "src/**/*.test.ts"],
  "exclude": ["node_modules", "dist"]
}
